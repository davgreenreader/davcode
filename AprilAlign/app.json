{
  "expo": {
    "name": "AprilAlign",
    "slug": "april-align",
    "scheme": "aprilalign",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aprilalign.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSBluetoothAlwaysUsageDescription": "AprilAlign uses Bluetooth to receive alignment data from the Pi camera system.",
        "NSBluetoothPeripheralUsageDescription": "AprilAlign uses Bluetooth to receive alignment data from the Pi camera system.",
        "UIBackgroundModes": ["bluetooth-central"]
      }
    },
    "android": {
      "package": "com.aprilalign.app",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "AprilAlign uses Bluetooth to receive alignment data from the Pi camera system."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
