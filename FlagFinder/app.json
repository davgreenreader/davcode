{
  "expo": {
    "name": "Flag Finder",
    "slug": "flag-finder",
    "scheme": "flagfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1a0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flagfinder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Flag Finder needs camera access to detect the AruCo tag on the flag."
      }
    },
    "android": {
      "package": "com.flagfinder.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Flag Finder needs camera access to detect the AruCo tag on the flag.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "Flag Finder uses Bluetooth to find and connect to your flag device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}